# ── Data paths ────────────────────────────────────────────────────────────────
DATA_CSV=data/HI-Small_Trans.csv
GRAPH_PATH=ml/graph.gpickle
EMBEDDINGS_PATH=ml/embeddings.npy
RINGS_PATH=ml/rings.json

# ── Days of data to load (each day ≈ 500K transactions) ──────────────────────
DAYS_TO_LOAD=3

# ── Node2Vec ──────────────────────────────────────────────────────────────────
NODE2VEC_DIMS=64
NODE2VEC_WALK_LENGTH=20
NODE2VEC_WALKS_PER_NODE=10
NODE2VEC_EPOCHS=5

# ── Isolation Forest ─────────────────────────────────────────────────────────
IF_ESTIMATORS=200
IF_CONTAMINATION=0.01

# ── Fund Flow Propagation ─────────────────────────────────────────────────────
PROPAGATION_DECAY=0.5
PROPAGATION_ITERS=3

# ── GraphSAGE ─────────────────────────────────────────────────────────────────
GRAPHSAGE_HIDDEN=64
GRAPHSAGE_EPOCHS=50

# ── Ring Detection ────────────────────────────────────────────────────────────
LOUVAIN_FRAUD_PROB_THRESHOLD=0.5
RING_MIN_NODES=3

# ── API ───────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
